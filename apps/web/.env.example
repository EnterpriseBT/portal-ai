# Auth0 Configuration
# Find these in the Auth0 dashboard under Applications > your SPA app.
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_AUDIENCE=https://your-tenant.us.auth0.com

# Build metadata (injected by CI pipeline; safe defaults for local dev)
VITE_APP_VERSION=dev
VITE_APP_SHA=local

# API base URL prepended to all /api/* requests.
# Empty in local dev — the Vite dev server proxies /api/* to localhost:3001.
# In deployed environments set this to the full API origin (e.g. https://api-dev.portalsai.io).
VITE_API_BASE_URL=
