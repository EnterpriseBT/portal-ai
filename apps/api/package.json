{
  "name": "@portalai/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run db:seed && npm run swagger:generate",
    "dev": "concurrently --names server,tunnel --prefix-colors blue,green \"dotenv -e .env -- nodemon\" \"dotenv -e .env -- ngrok http 3001\"",
    "predev:server": "npm run swagger:generate",
    "dev:server": "dotenv -e .env -- nodemon",
    "build": "dotenv -e .env -- tsc --project tsconfig.build.json",
    "start": "dotenv -e .env -- node dist/index.js",
    "clean": "rm -rf dist .turbo node_modules",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "swagger:generate": "dotenv -e .env -- tsx src/scripts/generate-swagger.ts",
    "swagger:watch": "dotenv -e .env -- nodemon --watch src --ext ts --exec 'npm run swagger:generate'",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules --import tsx/esm --max-old-space-size=4096' jest --config jest.integration.config.js --runInBand",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:migrate:ci": "drizzle-kit migrate",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "db:studio": "dotenv -e .env -- drizzle-kit studio",
    "db:seed": "dotenv -e .env -- tsx src/db/seed.ts",
    "db:seed:ci": "node dist/db/seed.js",
    "db:reset:hard": "dotenv -e .env -- tsx src/db/reset-hard.ts",
    "db:reset": "dotenv -e .env -- tsx src/db/reset.ts",
    "tunnel": "dotenv -e .env -- ngrok http 3001"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/groq": "^3.0.29",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@portalai/core": "*",
    "@tavily/core": "^0.4.0",
    "alasql": "^4.17.0",
    "arquero": "^8.0.3",
    "bullmq": "^5.71.0",
    "chardet": "^2.1.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "financial": "^0.2.4",
    "ioredis": "^5.10.0",
    "ml-kmeans": "^7.0.0",
    "ollama-ai-provider-v2": "^3.3.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "simple-statistics": "^7.8.9",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "technicalindicators": "^3.1.0",
    "vega": "^5.30.0",
    "vega-lite": "^5.21.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@types/chardet": "^0.8.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
