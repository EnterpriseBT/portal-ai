{
  "name": "@mcp-ui/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- nodemon",
    "build": "dotenv -e .env -- tsc",
    "start": "dotenv -e .env -- node dist/index.js",
    "clean": "rm -rf dist .turbo node_modules",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "swagger:generate": "dotenv -e .env -- tsx src/scripts/generate-swagger.ts",
    "swagger:watch": "dotenv -e .env -- nodemon --watch src --ext ts --exec 'npm run swagger:generate'",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.integration.config.js --runInBand",
    "db:generate": "dotenv -e .env -- node -r tsx/cjs ../../node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "dotenv -e .env -- node -r tsx/cjs ../../node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "dotenv -e .env -- node -r tsx/cjs ../../node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "dotenv -e .env -- node -r tsx/cjs ../../node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "dotenv -e .env -- tsx src/db/seed.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:3001"
  },
  "dependencies": {
    "@mcp-ui/core": "*",
    "cors": "^2.8.5",
    "drizzle-zod": "^0.8.3",
    "express": "^4.21.0",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "cloudflared": "^0.7.1",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
