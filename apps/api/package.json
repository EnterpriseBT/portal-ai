{
  "name": "@mcp-ui/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- nodemon",
    "build": "dotenv -e .env -- tsc",
    "start": "dotenv -e .env -- node dist/index.js",
    "clean": "rm -rf dist .turbo node_modules",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "swagger:generate": "dotenv -e .env -- tsx src/scripts/generate-swagger.ts",
    "swagger:watch": "dotenv -e .env -- nodemon --watch src --ext ts --exec 'npm run swagger:generate'"
  },
  "dependencies": {
    "@mcp-ui/types": "*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
