# Server Configuration
PORT=3001

# CORS Configuration (comma-separated urls)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Auth0 Configuration
AUTH0_AUDIENCE=https://api.mcp-ui.dev
AUTH0_DOMAIN=dev-xxxxxxxxxxxxxxxxx.us.auth0.com

# Logging Configuration
# LOG_LEVEL: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# LOG_FORMAT: pretty (colorized, human-readable) or json (structured) (default: pretty)
LOG_FORMAT=pretty

# Database Configuration
# Use "postgres" as the host when running inside the devcontainer (docker-compose network)
# Use "localhost" if running the API outside of Docker with a local/forwarded Postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/portal_ai

# Used in uuidv5 for securing ids
NAMESPACE=portalai-dev-namespace

# Auth0 Webhook Secret (shared secret for HMAC-SHA256 signature verification)
AUTH0_WEBHOOK_SECRET=your-webhook-secret-here

# System identifier
SYSTEM_ID="SYSTEM"

# Build metadata (injected by CI pipeline; safe defaults for local dev)
BUILD_VERSION=dev
BUILD_SHA=local

# Encryption key for securing connector credentials at rest (base64-encoded, 32 bytes)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Redis Configuration
# Use "redis" as the host when running inside the devcontainer (docker-compose network)
# Use "localhost" if running the API outside of Docker with a local/forwarded Redis
REDIS_URL=redis://redis:6379
# If running outside Docker, use: redis://localhost:6380

# ngrok auth token (used for webhook tunneling to localhost)
NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# AWS S3 Configuration (file uploads)
# Credentials are resolved automatically via the AWS SDK credential chain:
#   1. These env vars  2. ~/.aws/credentials  3. IAM instance role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=us-east-1
UPLOAD_S3_PREFIX=uploads
UPLOAD_S3_PRESIGN_EXPIRY_SEC=900
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_MAX_FILES=5
UPLOAD_ALLOWED_EXTENSIONS=.csv
