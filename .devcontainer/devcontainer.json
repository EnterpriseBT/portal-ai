{
  "name": "Portal.ai",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000, 3001, 5432, 7006, 7007, 4983],
  "portsAttributes": {
    "3000": {
      "label": "Web App"
    },
    "3001": {
      "label": "API"
    },
    "5432": {
      "label": "PostgreSQL"
    },
    "4983": {
      "label": "PostgreSQL"
    },
    "7006": {
      "label": "Storybook Core"
    },
    "7007": {
      "label": "Storybook App"
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind,consistency=cached"
  ],
  "remoteUser": "root",
  "onCreateCommand": "npm i"
}
