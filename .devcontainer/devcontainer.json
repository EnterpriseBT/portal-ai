{
  "name": "MCP UI",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000, 3001, 5432, 6006, 6007, 4983],
  "portsAttributes": {
    "3000": {
      "label": "Web App"
    },
    "3001": {
      "label": "API"
    },
    "5432": {
      "label": "PostgreSQL"
    },
    "4983": {
      "label": "PostgreSQL"
    },
    "6006": {
      "label": "Storybook"
    },
    "6007": {
      "label": "Additional Service"
    }
  },
  "onCreateCommand": "npm i",
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code"
}
