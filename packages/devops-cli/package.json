{
  "name": "@portalai/devops-cli",
  "version": "0.0.0",
  "type": "module",
  "description": "portalops — Portal's infrastructure operator CLI (DB tunnels/reset/seed, Secrets Manager + SSM config catalog) over @portalai/cli-env. TypeScript port of apps/api/scripts/api-cli.sh. Node-only.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "portalops": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc --project tsconfig.build.json && chmod +x dist/bin.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "type-check": "tsc --project tsconfig.eslint.json --noEmit",
    "clean": "rm -rf dist",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:integration": "true",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.1084.0",
    "@portalai/cli-env": "*",
    "commander": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
