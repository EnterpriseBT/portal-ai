{
  "name": "@mcp-ui/core",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./dist/styles/index.css",
    "./styles/fonts": "./dist/styles/fonts.css",
    "./styles/global": "./dist/styles/global.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:ts && npm run build:scss && npm run build:assets",
    "build:ts": "tsc",
    "build:scss": "sass src/assets/scss:dist/styles --no-source-map",
    "build:assets": "cp -r src/assets/fonts dist/fonts && cp -r src/assets/themes dist/themes",
    "dev": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:ui": "NODE_OPTIONS=--experimental-vm-modules jest --watch --verbose=false"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-interactions": "^8.6.15",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.15",
    "@storybook/test": "^8.6.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.97.3",
    "storybook": "^8.6.15",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7"
  }
}
